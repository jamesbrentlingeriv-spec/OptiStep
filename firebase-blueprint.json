{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress data.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "completedModules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "completedModules", "createdAt"]
    },
    "Module": {
      "title": "Module",
      "description": "Information about a training module.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "videoUrl": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["title", "description", "order"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user documents keyed by UID."
    },
    "modules": {
      "schema": "Module",
      "description": "Collection of training modules."
    }
  }
}
